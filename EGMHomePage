    ),
url('PLACEHOLDER-HERO-IMAGE.jpg');
    background-size: cover;
     background-position: center;
         padding: 120px 40px;
             text-align: center;
                   color: var(--text-light);
}

.hero h1 {
    font-size: 48px;
     margin-bottom: 10px;
}

.hero p {
    font-size: 20px;
     margin-bottom: 20px;
}

.hero button {
    padding: 12px 25px;
     background: var(--suburban-dark);
         border: none;
             font-size: 18px;
                    cursor: pointer;
                     border-radius: 6px;
                         box-shadow: 0 3px 6px var(--accent-shadow);
}

.hero button:hover {
    background: var(--suburban-light);
}

                                                                                            /* SECTIONS */
.section {
    padding: 60px 40px;
}

.section h2 {
    color: var(--forest-green);
     margin-bottom: 20px;
}

                                                                                            /* SERVICES GRID */
.services-grid {
    display: grid;
     grid-template-columns: repeat(4, 1fr);
         gap: 25px;
}

.service-box {
    background: white;
        padding: 25px;
            border-radius: 8px;
                box-shadow: 0 3px 6px var(--accent-shadow);
}

                                                                                                        /* FOOTER */
footer {
    background: var(--forest-green);
      color: var(--text-light);
         padding: 30px;
             text-align: center;
                 margin-top: 40px;
}

footer a {
    color: var(--suburban-dark);
        text-decoration: none;
            font-weight: bold;
}
